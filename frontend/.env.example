# Frontend (Vite) .env.example for project-pulse
# Copy to `.env` or `.env.local` at the frontend root and replace values.

# Base URL for backend API (used by `src/api/api.js`)
VITE_API_BASE_URL=http://localhost:5000

# Clerk publishable key (used by frontend)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Notes:
# - Vite requires keys exposed to the client to start with `VITE_`.
# - Do not store sensitive server-only secrets here.
