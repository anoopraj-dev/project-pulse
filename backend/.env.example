# Backend .env.example for project-pulse
# Copy this file to `.env` and replace placeholder values with real secrets.

# Server
PORT=5000

# Database (MongoDB connection string)
# Example: mongodb://username:password@host:port/database
DB_URL=mongodb://localhost:27017/pulse-db

# JWT secret used to sign auth tokens
JWT_SECRET=your_jwt_secret_here

# Nodemailer / Gmail (use App Passwords if using Google accounts)
GMAIL_USER=your.email@gmail.com
GMAIL_PASS=your_gmail_app_password

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Clerk (third-party auth/webhook secrets used by backend)
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret

# Notes:
# - Never commit your real `.env` file to version control.
# - Use strong, random values for `JWT_SECRET` and webhook secrets.
# - If you run the backend in a container or cloud, inject env vars securely.
